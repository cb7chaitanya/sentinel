SERVICE_NAME=events
ENVIRONMENT=local
HOST=0.0.0.0
PORT=8003
LOG_LEVEL=INFO
LOG_JSON=true

DWELL_TIME_THRESHOLD_SECONDS=30
MEMORY_SERVICE_URL=http://memory:8004

# camera_id below matches the webcam entry in ingestion's own
# CAMERA_SOURCES example, so the two services' examples describe one
# coherent local pipeline rather than unrelated placeholder data.
ZONES=[{"id":"92ffa909-712d-4a8a-a794-28998b0c614a","warehouse_id":"2aab3bf7-0031-435c-a4fd-6582a3270c79","camera_id":"cf0a41e8-04cb-4347-93c7-386e71946af0","name":"Loading Dock","polygon":{"points":[{"x":0,"y":0},{"x":640,"y":0},{"x":640,"y":480},{"x":0,"y":480}]}}]
ZONE_EXIT_GRACE_PERIOD_SECONDS=0.0

# Every camera ingestion is configured to capture from should have an
# entry here (see Settings.camera_warehouse_map's docstring) -- this
# covers both cameras in ingestion's example CAMERA_SOURCES.
CAMERA_WAREHOUSE_MAP={"d6d1a78a-b2af-4ac4-a333-8c7290ccaf43":"2aab3bf7-0031-435c-a4fd-6582a3270c79","cf0a41e8-04cb-4347-93c7-386e71946af0":"2aab3bf7-0031-435c-a4fd-6582a3270c79"}

MOTION_SPEED_THRESHOLD=5.0
WORKER_LABELS=["person"]
WORKER_DISPLAY_NAME=Worker
